#!/usr/bin/env bash
# Run a caos-tool by hand: fire the given tool script as a caos job over
# this repo's tree — exactly what an agent's tool invocation does. The tool
# runs in a bash worker with the tracked worktree (dirty edits included) as
# --in, plus any extra --name=value args verbatim.
#
# Usage: ./run-tool <tool-script | name> [--name=value ...]
#   ./run-tool caos-tools/build.sh
#   ./run-tool test --only="symlinks unit"
#   ./run-tool caos-tools/test.sh --api_key="$ANTHROPIC_API_KEY"
#
# The result is checked out under .caos-dev/tool-<name>. By convention a
# tool result may carry a `report` (printed; a FAILED banner fails this
# script) and `results/<name>/` records (failing entries' output tails are
# shown). Unsalted: unchanged inputs are cache hits; export CAOS_SALT to
# force a re-run.
set -uo pipefail
cd "$(dirname "$0")"

[ $# -ge 1 ] || { echo "usage: ./run-tool <tool-script|name> [--name=value ...]" >&2; exit 2; }
tool=$1; shift
case "$tool" in
  */* | *.sh) script=$tool ;;
  *) script=caos-tools/$tool.sh ;;
esac
[ -f "$script" ] || { echo "no such tool script: $script" >&2; exit 2; }
name=$(basename "$script" .sh)

# The client and the stack are REQUIRED, never produced: both are the old,
# known-good caos (`caosd up` deploys them together); everything under test
# is built by caos jobs from this tree.
CAOS_DATA="${CAOS_DATA:-$PWD/.caos-data}"
CAOS_CLI=${CAOS_CLI:-$(command -v caos-cli || true)}
[ -n "$CAOS_CLI" ] || [ ! -x "$CAOS_DATA/bin/caos-cli" ] || CAOS_CLI=$CAOS_DATA/bin/caos-cli
[ -n "$CAOS_CLI" ] || {
  echo "run-tool: no caos client found (CAOS_CLI, PATH, $CAOS_DATA/bin)." >&2
  echo "the stack's deploy installs one: nix run .#caosd -- up" >&2
  exit 1
}
git remote get-url caos >/dev/null 2>&1 || {
  echo "run-tool: this repo needs a 'caos' remote naming the local server:" >&2
  echo "  git remote add caos http://localhost:9090" >&2
  exit 1
}

OUT=$PWD/.caos-dev/tool-$name
rm -rf "$OUT"
result=$(CAOS_SALT="${CAOS_SALT:-}" "$CAOS_CLI" run /cas/std/bash "$OUT" -- \
  "--script:@=$script" --in:@=. "$@") \
  || { echo "run-tool: $name failed" >&2; exit 1; }
echo "$name: $result (checked out at $OUT)" >&2

if [ -f "$OUT/report" ]; then
  echo >&2
  cat "$OUT/report" >&2
  if [ -d "$OUT/results" ]; then
    for r in "$OUT"/results/*/; do
      t=$(basename "$r")
      [ -f "$r/verdict" ] && ! grep -q "PASS" "$r/verdict" || continue
      { echo; echo "---- $t (output tail; full record in results/$t) ----"
        tail -40 "$r/output" 2>/dev/null; } >&2
    done
  fi
  grep -q "FAILED" "$OUT/report" && exit 1
fi
exit 0
